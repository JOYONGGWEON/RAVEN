# 서버 포트
PORT=3001

# 프론트엔드 주소 (CORS 허용 origin) - GitHub Pages 배포 주소로 교체
FRONTEND_ORIGIN=http://localhost:5500

# PIN 잠금 화면 비밀번호 (기존 클라이언트에 평문 노출되던 값)
RAVEN_PIN=0524

# 토스증권 Open API (Phase 1에서 실제 연동 시 사용)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# 텔레그램 알림 봇 (Phase 3에서 사용)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 한국투자증권 KIS Developers API (Phase 2 수급데이터 전용 - 시세/차트는 토스 사용)
KIS_APP_KEY=
KIS_APP_SECRET=

# Supabase (수급데이터 캐시 저장용)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API (Phase 4 - 실제 AI 서술 분석)
